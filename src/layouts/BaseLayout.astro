---
import "../styles/global.css";
const { title = "SportingLinx", description = "Sporting discovery across the VTL Evosystem." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>